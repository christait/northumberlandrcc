---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = await getCollection('events', ({ data }) => !data.draft);
const now = Date.now();
const upcoming = all
  .filter((e) => e.data.date.getTime() >= now - 86400000)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const past = all
  .filter((e) => e.data.date.getTime() < now - 86400000)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmtDate = (d: Date) =>
  d.toLocaleString('en-GB', {
    weekday: 'short',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
---

<BaseLayout title="Events" description="Forthcoming and recent events for the Northumberland Division.">
  <section class="section">
    <div class="container">
      <span class="eyebrow">Diary</span>
      <h1>Events</h1>

      <h2 style="margin-top:1.5rem;">Forthcoming</h2>
      {upcoming.length === 0 ? (
        <p class="muted">No forthcoming events at this time.</p>
      ) : (
        <div class="grid cols-2">
          {upcoming.map((e) => (
            <article class="card">
              <p class="muted small">{fmtDate(e.data.date)}{e.data.location ? ` · ${e.data.location}` : ''}</p>
              <h3><a href={`/events/${e.slug}/`}>{e.data.title}</a></h3>
              {e.data.summary && <p class="muted">{e.data.summary}</p>}
            </article>
          ))}
        </div>
      )}

      {past.length > 0 && (
        <>
          <h2 style="margin-top:3rem;">Recent past</h2>
          <ul class="past-list">
            {past.slice(0, 10).map((e) => (
              <li>
                <span class="muted small">{fmtDate(e.data.date)}</span> —
                <a href={`/events/${e.slug}/`}>{e.data.title}</a>
              </li>
            ))}
          </ul>
        </>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .small { font-size: 0.85rem; }
  .past-list { list-style: none; padding: 0; }
  .past-list li { padding: 0.4rem 0; border-bottom: 1px solid var(--colour-border); }
</style>
