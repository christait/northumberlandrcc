---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const events = await getCollection('events', ({ data }) => !data.draft);
  return events.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmtDate = (d: Date) =>
  d.toLocaleString('en-GB', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="section">
    <div class="container prose">
      <p><a href="/events/">← All events</a></p>
      <span class="eyebrow">Event</span>
      <h1>{entry.data.title}</h1>
      <ul class="meta">
        <li><strong>When:</strong> {fmtDate(entry.data.date)}</li>
        {entry.data.location && <li><strong>Where:</strong> {entry.data.location}</li>}
        {entry.data.rsvp && <li><a class="button" href={entry.data.rsvp}>RSVP</a></li>}
      </ul>
      <hr />
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .meta { list-style: none; padding: 0; margin: 1rem 0; }
  .meta li { padding: 0.25rem 0; }
</style>
