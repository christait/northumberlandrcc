---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const conclaves = (await getCollection('conclaves')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<BaseLayout title="Conclaves" description="Conclaves of the Order working in the Division of Northumberland.">
  <section class="section">
    <div class="container">
      <span class="eyebrow">Where we meet</span>
      <h1>Conclaves of the Division</h1>
      <p class="muted">Five Conclaves work in the Northumberland Division.</p>

      <div class="table-wrap" style="margin-top:2rem;">
        <table class="conclaves-table">
          <thead>
            <tr>
              <th scope="col">Conclave</th>
              <th scope="col">No.</th>
              <th scope="col">Venue</th>
              <th scope="col">Recorder</th>
            </tr>
          </thead>
          <tbody>
            {conclaves.map((c) => (
              <tr>
                <th scope="row"><a href={`/conclaves/${c.slug}/`}>{c.data.name}</a></th>
                <td>{c.data.number ?? ''}</td>
                <td>{c.data.meetingPlace ?? ''}</td>
                <td>
                  {c.data.recorder && <span>{c.data.recorder}</span>}
                  {c.data.recorder && c.data.recorderEmail && <br />}
                  {c.data.recorderEmail && (
                    <a href={`mailto:${c.data.recorderEmail}`}>{c.data.recorderEmail}</a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="grid cols-2" style="margin-top:2.5rem;">
        {conclaves.map((c) => (
          <article class="card">
            <h3 style="margin-bottom:0.4rem;">
              <a href={`/conclaves/${c.slug}/`}>{c.data.name}{c.data.number ? ` No. ${c.data.number}` : ''}</a>
            </h3>
            {c.data.meetingPlace && <p class="muted small">📍 {c.data.meetingPlace}</p>}
            {c.data.meetingDates && <p class="muted small">🗓 {c.data.meetingDates}</p>}
            {c.data.consecrated && <p class="muted small">Consecrated {c.data.consecrated}</p>}
            {c.data.recorderEmail && (
              <p class="muted small">
                ✉ <a href={`mailto:${c.data.recorderEmail}`}>{c.data.recorderEmail}</a>
              </p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .small { font-size: 0.85rem; }
  .table-wrap { overflow-x: auto; }
  .conclaves-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--colour-surface);
    border: 1px solid var(--colour-border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .conclaves-table th,
  .conclaves-table td {
    text-align: left;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--colour-border);
    vertical-align: top;
    font-size: 0.95rem;
  }
  .conclaves-table thead th {
    background: rgba(139, 26, 26, 0.06);
    font-family: var(--font-sans);
    font-weight: 700;
    color: var(--colour-primary-dark);
    letter-spacing: 0.04em;
  }
  .conclaves-table tbody tr:last-child th,
  .conclaves-table tbody tr:last-child td {
    border-bottom: none;
  }
  .conclaves-table tbody th {
    font-weight: 600;
    white-space: nowrap;
  }
</style>
