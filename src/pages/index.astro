---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import siteConfig from '../config/site.json';

const news = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const upcoming = (await getCollection('events', ({ data }) => !data.draft))
  .filter((e) => e.data.date.getTime() >= Date.now() - 86400000)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
---

<BaseLayout>
  <section class="hero">
    <div class="container hero-inner">
      <span class="eyebrow">Order of the Red Cross of Constantine</span>
      <h1>{siteConfig.title}</h1>
      <p class="hero-lead">
        Welcoming Royal Arch Masons of the Trinitarian Christian faith into the fellowship of the
        Red Cross of Constantine and its appendant Orders across Northumberland.
      </p>
      <div class="hero-actions">
        <a class="button" href="/history/">About the Division</a>
        <a class="button secondary" href="/contact/">Enquire about membership</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid cols-3">
      <article class="card">
        <span class="eyebrow">Conclaves</span>
        <h3>Where we meet</h3>
        <p class="muted">Find the Conclaves working in Northumberland, their meeting places and dates.</p>
        <p><a href="/conclaves/">View all Conclaves →</a></p>
      </article>
      <article class="card">
        <span class="eyebrow">Executive</span>
        <h3>Divisional team</h3>
        <p class="muted">Meet the Executive who serve the Division and oversee its work.</p>
        <p><a href="/executive/">Meet the Executive →</a></p>
      </article>
      <article class="card">
        <span class="eyebrow">History</span>
        <h3>Our heritage</h3>
        <p class="muted">A short history of the Order and the Northumberland Division.</p>
        <p><a href="/history/">Read the history →</a></p>
      </article>
    </div>
  </section>

  {upcoming.length > 0 && (
    <section class="section alt">
      <div class="container">
        <span class="eyebrow">Upcoming</span>
        <h2>Forthcoming events</h2>
        <div class="grid cols-2">
          {upcoming.map((e) => (
            <article class="card">
              <p class="muted small">{fmtDate(e.data.date)}{e.data.location ? ` · ${e.data.location}` : ''}</p>
              <h3><a href={`/events/${e.slug}/`}>{e.data.title}</a></h3>
              {e.data.summary && <p class="muted">{e.data.summary}</p>}
            </article>
          ))}
        </div>
        <p style="margin-top:1.5rem"><a href="/events/">All events →</a></p>
      </div>
    </section>
  )}

  {news.length > 0 && (
    <section class="section">
      <div class="container">
        <span class="eyebrow">Latest</span>
        <h2>News &amp; notices</h2>
        <div class="grid cols-2">
          {news.map((n) => (
            <article class="card">
              <p class="muted small">{fmtDate(n.data.date)}</p>
              <h3><a href={`/news/${n.slug}/`}>{n.data.title}</a></h3>
              {n.data.summary && <p class="muted">{n.data.summary}</p>}
            </article>
          ))}
        </div>
        <p style="margin-top:1.5rem"><a href="/news/">All news →</a></p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.85), rgba(251, 248, 243, 0.95)),
      radial-gradient(circle at 20% 0%, rgba(176, 138, 62, 0.18), transparent 40%),
      radial-gradient(circle at 80% 100%, rgba(139, 26, 26, 0.15), transparent 50%);
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--colour-border);
  }
  .hero-inner {
    max-width: 48rem;
    text-align: center;
  }
  .hero-lead {
    font-size: 1.2rem;
    color: var(--colour-muted);
  }
  .hero-actions {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.5rem;
  }
  .small { font-size: 0.85rem; }
</style>
